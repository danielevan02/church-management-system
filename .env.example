# =====================================================================
# Church Management System — Environment Variables
# Copy this file to `.env.local` (or `.env` in production) and fill in
# real values. Never commit the populated file to git.
# =====================================================================

# ─────────────────────────────────────────────────────────────────────
# Database (REQUIRED)
# ─────────────────────────────────────────────────────────────────────
# DATABASE_URL  : connection string used at runtime (pooled connection
#                 if your provider offers one — Neon/Supabase do).
# DIRECT_URL    : direct connection used by `prisma migrate`. If your
#                 provider doesn't separate pooled/direct, set both to
#                 the same value.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─────────────────────────────────────────────────────────────────────
# Auth.js v5 (REQUIRED)
# Generate AUTH_SECRET with: openssl rand -base64 32
# AUTH_URL must match the public origin (no trailing slash).
# AUTH_TRUST_HOST=true is required behind a proxy / Vercel.
# ─────────────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-32-byte-random-string"
AUTH_URL="https://your-church.example.com"
AUTH_TRUST_HOST="true"

# ─────────────────────────────────────────────────────────────────────
# Initial admin (REQUIRED for first deploy — used by `prisma db seed`)
# Change INITIAL_ADMIN_PASSWORD immediately after first sign-in.
# ─────────────────────────────────────────────────────────────────────
INITIAL_ADMIN_EMAIL="admin@your-church.example.com"
INITIAL_ADMIN_PASSWORD="change-me-after-first-login"

# ─────────────────────────────────────────────────────────────────────
# App (REQUIRED)
# ─────────────────────────────────────────────────────────────────────
APP_TIMEZONE="Asia/Jakarta"
NODE_ENV="production"

# ─────────────────────────────────────────────────────────────────────
# Web Push / VAPID (OPTIONAL — required to send push notifications)
# Generate keys: pnpm exec web-push generate-vapid-keys --json
# Public key is exposed to the browser via NEXT_PUBLIC_*; private key
# stays server-side. VAPID_SUBJECT is a contact URL Push services can
# reach you on (mailto:* or https://*).
# Leave empty to disable push entirely (announcements still work in-app).
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@your-church.example.com"

# ─────────────────────────────────────────────────────────────────────
# Church branding — public, exposed to the browser (REQUIRED)
# These drive the app name, manifest, theme color, and locale.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHURCH_NAME="Gereja Contoh"
NEXT_PUBLIC_CHURCH_SHORT_NAME="GC"
NEXT_PUBLIC_CHURCH_DOMAIN="your-church.example.com"
NEXT_PUBLIC_DEFAULT_LOCALE="id"
NEXT_PUBLIC_PRIMARY_COLOR="#0F766E"

# ─────────────────────────────────────────────────────────────────────
# Giving / persembahan — public (OPTIONAL, but used by giving forms)
# Leave QRIS_IMAGE_PATH pointing at /qris.png and place the file in
# /public to enable QRIS as a payment option. Leave WA empty to hide
# the post-transfer confirmation prompt.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHURCH_BANK_NAME="BCA"
NEXT_PUBLIC_CHURCH_BANK_ACCOUNT_NUMBER="0000000000"
NEXT_PUBLIC_CHURCH_BANK_ACCOUNT_HOLDER="Yayasan Gereja Contoh"
NEXT_PUBLIC_CHURCH_QRIS_IMAGE_PATH="/qris.png"
NEXT_PUBLIC_CHURCH_GIVING_CONFIRM_WA=""

# ─────────────────────────────────────────────────────────────────────
# Messaging providers (OPTIONAL — default "stub" logs to server console)
# WHATSAPP_PROVIDER : "stub" | "fonnte"
# EMAIL_PROVIDER    : "stub"
# Use "stub" in dev. The Fonnte adapter is scaffolded but not yet wired
# — see src/lib/whatsapp.ts.
# ─────────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER="stub"
EMAIL_PROVIDER="stub"

# ─────────────────────────────────────────────────────────────────────
# Error tracking — Sentry (OPTIONAL but recommended for production)
# Leave NEXT_PUBLIC_SENTRY_DSN empty to disable Sentry entirely (the SDK
# silently no-ops). Set DSN in production to capture errors. SENTRY_ORG
# + SENTRY_PROJECT + SENTRY_AUTH_TOKEN are only needed if you want
# source-map uploads for readable stack traces (build-time only).
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

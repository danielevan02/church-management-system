{
  "name": "church-management-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/build-sw.cjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/build-sw.cjs",
    "build": "prisma migrate deploy && prisma generate && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "icons": "node scripts/generate-icons.cjs",
    "admin:reset-password": "tsx scripts/reset-admin-password.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "html5-qrcode": "^2.3.8",
    "import-in-the-middle": "^3.0.1",
    "input-otp": "^1.4.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.11.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.0",
    "require-in-the-middle": "^8.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tiptap-markdown": "^0.9.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "esbuild"
    ]
  }
}
